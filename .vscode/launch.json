{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb-dap",
      "request": "launch",
      "name": "(lldb-dap) LLDB launch current CMake target",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": [
        "PATH=$PATH:${command:cmake.launchTargetDirectory}",
      ],
      "preRunCommands": [
        // Requires LLDB 22+
        "command script import ${workspaceFolder}/coro_backtrace_lldb.py"
      ]
    },
    {
      "type": "cppdbg",
      "name": "(cppdbg) GDB launch current CMake target",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "$PATH:${command:cmake.launchTargetDirectory}"
        }
      ],
      "logging": {
        "trace": true
      },
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        // Note: Async backtrace frames require a patched cpptools MIEngine adapter.
        // Stock MIEngine crashes the stack walk on the synthetic async frames because
        // they lack the `level` field (MICore's FindUint("level") throws). The patch
        // (DebuggedThread.CreateContext / DebuggedProcess.GetParameterInfoOnly) falls
        // back to the frame's position index when `level` is absent. Without that
        // patch, use `bt` in the Debug Console or the LLDB configuration instead.
        {
          "description": "Enable frame filters for MI mode",
          "text": "-enable-frame-filters",
          "ignoreFailures": true
        }
      ],
      "miDebuggerArgs": "-x ${workspaceFolder}/coro_backtrace_gdb.py",
      // Show the locals of a suspended coroutine (a synthetic async frame) in the
      // Variables pane. Such frames have no selectable `--frame` index, so MIEngine
      // evaluates these expressions instead: the names expression yields the member
      // names, and each local is read as "(<locals expr>).<name>". Requires the patched
      // MIEngine adapter and the convenience functions in coro_backtrace_gdb.py.
      "syntheticFrameLocalsExpression": "*$__coro_frame_at({address})",
      "syntheticFrameLocalNamesExpression": "$__coro_local_names({address})",
    }
  ]
}
